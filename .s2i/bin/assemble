#!/usr/bin/env bash
set -euo pipefail

APP_SRC="$(pwd)"
DEFAULT_ASSEMBLE="${S2I_DEFAULT_ASSEMBLE:-/usr/libexec/s2i/assemble}"

if [ -x "$DEFAULT_ASSEMBLE" ]; then
    "$DEFAULT_ASSEMBLE"
else
    PYTHON_BIN="${PYTHON_BIN:-python}"
    if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
        PYTHON_BIN="python3"
    fi
    if [ -f requirements.txt ]; then
        "$PYTHON_BIN" -m pip install --upgrade pip
        "$PYTHON_BIN" -m pip install -r requirements.txt
    fi
fi

cd "$APP_SRC"
echo "S2I assemble complete. CMSSW is installed at runtime into the configured writable volume."
